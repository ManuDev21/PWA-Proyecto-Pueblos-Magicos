# ÍXA · Backend environment
# ──────────────────────────────────────────────
# LOCAL (desarrollo)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ixa_db

ADMIN_EMAIL=AdminIXA@UTCancun.com

# CORS (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ──────────────────────────────────────────────
# PRODUCCIÓN (Render + Aiven MySQL)
# Configurar estas variables en el dashboard de Render:
#
# DB_HOST      = mysql-xxxxx.aivencloud.com  (host de Aiven)
# DB_PORT      = 12345                       (puerto SSL de Aiven)
# DB_USER      = avnadmin                    (usuario por defecto Aiven)
# DB_PASSWORD  = tu_password_de_aiven
# DB_NAME      = defaultdb                   (nombre BD en Aiven)
# CORS_ORIGINS = https://tu-frontend.vercel.app
#
# Nota: Aiven requiere conexión SSL. Ver backend/app/core/database.py
# para activar ssl=true en producción.
